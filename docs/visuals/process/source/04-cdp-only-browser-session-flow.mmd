  E -- "no" --> G["Forward call to CDP"]
  G --> H["enableDomains Page/DOM/Input/Network/Accessibility as needed"]
  H --> I["DOM roots, frames, selectors, box models, AX tree"]
  I --> J["Input.dispatchMouseEvent / key / text / wheel"]
  J --> K["assertNoForbiddenCdpCalls before returning"]
