  N -- "yes" --> O["Click 刷新 if present or refresh page; force recent_not_view"]
  O --> P["Reapply job/scope/filters and reset infinite-list round"]
  P --> L
  N -- "no" --> Z
  M -- "no" --> Q["Read card candidate"]
  Q --> R{"detailLimit allows detail?"}
  R -- "no" --> S["Screen from card data only"]
  R -- "yes" --> T["Open detail by CDP click"]
  T --> U["Acquire CV via network primary and image fallback"]
  U --> V["Normalize candidate profile"]
  V --> W["LLM/basic screenCandidate"]
